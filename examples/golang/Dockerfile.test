# Dockerfile.test
# Simplified Dockerfile for running Go tests against pg_facets
# Uses the existing docker/ setup as a base

FROM ubuntu:22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive \
    PG_MAJOR=17 \
    ZIG_VERSION=0.15.2

# Install system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        curl \
        ca-certificates \
        gnupg2 \
        git \
        cmake \
        gcc \
        libc-dev \
        make \
        pkg-config \
        libssl-dev \
        wget \
        xz-utils && \
    rm -rf /var/lib/apt/lists/*

# Add PostgreSQL Apt repository and install PostgreSQL development packages
RUN curl -sSL https://www.postgresql.org/media/keys/ACCC4CF8.asc | apt-key add - && \
    echo "deb http://apt.postgresql.org/pub/repos/apt/ jammy-pgdg main" > /etc/apt/sources.list.d/pgdg.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        postgresql-server-dev-$PG_MAJOR && \
    rm -rf /var/lib/apt/lists/*

# Install Zig (multi-arch) and lock Zig build target to GNU libc.
ARG TARGETARCH=amd64
RUN MACHINE="$(uname -m)" && \
    case "${MACHINE}" in \
      aarch64|arm64) RUNTIME_ARCH=arm64;; \
      x86_64|amd64) RUNTIME_ARCH=amd64;; \
      *) RUNTIME_ARCH="${TARGETARCH}";; \
    esac && \
    if [ "${TARGETARCH}" != "${RUNTIME_ARCH}" ]; then \
      echo "WARN: TARGETARCH=${TARGETARCH} differs from runtime arch ${RUNTIME_ARCH}; using runtime arch."; \
    fi && \
    case "${RUNTIME_ARCH}" in \
      arm64) ZIG_ARCH=aarch64-linux; ZIG_TARGET=aarch64-linux-gnu;; \
      *) ZIG_ARCH=x86_64-linux; ZIG_TARGET=x86_64-linux-gnu;; \
    esac && \
    printf '%s' "${ZIG_TARGET}" > /tmp/zig_target && \
    cd /tmp && \
    wget https://ziglang.org/download/${ZIG_VERSION}/zig-${ZIG_ARCH}-${ZIG_VERSION}.tar.xz && \
    tar -xf zig-${ZIG_ARCH}-${ZIG_VERSION}.tar.xz && \
    mv zig-${ZIG_ARCH}-${ZIG_VERSION} /usr/local/zig && \
    ln -s /usr/local/zig/zig /usr/local/bin/zig && \
    rm zig-${ZIG_ARCH}-${ZIG_VERSION}.tar.xz

# Clone, patch, and build roaringbitmap (no submodule required)
RUN cd /tmp && \
    git clone --depth 1 --branch master https://github.com/ChenHuajun/pg_roaringbitmap.git && \
    cd pg_roaringbitmap && \
    if ! grep -q 'non-x86 fallback for pg_facets integration' roaring.c; then \
      printf '%s\n' '' '// non-x86 fallback for pg_facets integration' '#if !defined(__x86_64__) && !defined(_M_AMD64)' 'int croaring_hardware_support(void) { return 0; }' '#endif' >> roaring.c; \
    fi && \
    make && \
    make install

# Copy pg_facets source (from build context)
COPY . /tmp/pg_facets

# Ensure deps/pg_roaringbitmap exists for zig build (build.zig expects it)
RUN mkdir -p /tmp/pg_facets/deps && cp -R /tmp/pg_roaringbitmap /tmp/pg_facets/deps/pg_roaringbitmap

# Build pg_facets
RUN cd /tmp/pg_facets && \
    ZIG_TARGET="$(tr -d '\n' </tmp/zig_target)" && \
    zig build -Dtarget="${ZIG_TARGET}" -Doptimize=ReleaseFast

# Verify build
RUN test -f /tmp/pg_facets/pg_facets.control && \
    test -f /tmp/pg_facets/sql/pg_facets--0.4.3.sql && \
    test -f /tmp/pg_facets/zig-out/lib/libpg_facets.so && \
    echo "All pg_facets files built successfully"

# ---------------------------
# Final Image
# ---------------------------
FROM pgvector/pgvector:pg17

ENV DEBIAN_FRONTEND=noninteractive \
    PG_MAJOR=17

# Copy roaringbitmap from builder
COPY --from=builder /usr/lib/postgresql/$PG_MAJOR/lib/roaringbitmap.so /usr/lib/postgresql/$PG_MAJOR/lib/
COPY --from=builder /usr/share/postgresql/$PG_MAJOR/extension/roaringbitmap.control /usr/share/postgresql/$PG_MAJOR/extension/
COPY --from=builder /usr/share/postgresql/$PG_MAJOR/extension/roaringbitmap--*.sql /usr/share/postgresql/$PG_MAJOR/extension/

# Copy pg_facets from builder
COPY --from=builder /tmp/pg_facets/zig-out/lib/libpg_facets.so /usr/lib/postgresql/$PG_MAJOR/lib/pg_facets.so
COPY --from=builder /tmp/pg_facets/pg_facets.control /usr/share/postgresql/$PG_MAJOR/extension/
# Copy all SQL files for version support (including 0.4.3)
COPY --from=builder /tmp/pg_facets/sql/pg_facets--*.sql /usr/share/postgresql/$PG_MAJOR/extension/

# Verify installation
RUN test -f /usr/share/postgresql/$PG_MAJOR/extension/pg_facets.control && \
    test -f /usr/share/postgresql/$PG_MAJOR/extension/pg_facets--0.4.3.sql && \
    test -f /usr/lib/postgresql/$PG_MAJOR/lib/pg_facets.so && \
    echo "pg_facets extension installed successfully (version 0.4.3)"

EXPOSE 5432
CMD ["postgres"]
